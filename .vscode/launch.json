{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NguonTin frontend: launch browser debug",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --hostname 127.0.0.1 --port 3001",
      "cwd": "${workspaceFolder}/frontend",
      "env": {
        "NEXT_PUBLIC_API_BASE_URL": "http://127.0.0.1:8010",
        "NEXT_PUBLIC_FRONTEND_URL": "http://127.0.0.1:3001",
        "FRONTEND_BASE_URL": "http://127.0.0.1:3001",
        "APP_ENV": "development"
      },
      "serverReadyAction": {
        "pattern": "- Local:\\s+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "NguonTin frontend: debug server-side",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--hostname", "127.0.0.1", "--port", "3001"],
      "env": {
        "NEXT_PUBLIC_API_BASE_URL": "http://127.0.0.1:8010",
        "NEXT_PUBLIC_FRONTEND_URL": "http://127.0.0.1:3001",
        "FRONTEND_BASE_URL": "http://127.0.0.1:3001",
        "APP_ENV": "development"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "NguonTin frontend: debug Playwright current file",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["playwright", "test", "${relativeFile}"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "NguonTin backend: debug FastAPI",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8010",
        "--reload"
      ],
      "envFile": "${workspaceFolder}/.env.local",
      "env": {
        "DATABASE_PATH": "${workspaceFolder}/backend/data/nguontin.db"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "NguonTin Backend (debug)",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "envFile": "${workspaceFolder}/.env.local",
      "env": {
        "DATABASE_PATH": "${workspaceFolder}/backend/data/nguontin.db"
      },
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "NguonTin full stack: frontend + backend",
      "configurations": [
        "NguonTin frontend: launch browser debug",
        "NguonTin backend: debug FastAPI"
      ],
      "stopAll": true
    }
  ]
}
