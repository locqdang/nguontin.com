COMPOSE_PROJECT_NAME=nguontin
FRONTEND_PORT=3007
BACKEND_PORT=8008
NEXT_PUBLIC_API_BASE_URL=https://api.nguontin.com
NEXT_PUBLIC_FRONTEND_URL=https://nguontin.com/
INTERNAL_API_BASE_URL=http://backend:8000
APP_NAME="NguonTin"
APP_ENV=development
APP_VERSION=0.1.0
DATABASE_PATH=/app/data/nguontin.db
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
EMAIL_LOGIN_CODE_TTL_MINUTES=15
EMAIL_DELIVERY_TIMEOUT_SECONDS=10
OAUTH_HTTP_TIMEOUT_SECONDS=10
N8N_EMAIL_LOGIN_WEBHOOK_URL=
N8N_EMAIL_LOGIN_WEBHOOK_SECRET=
FRONTEND_BASE_URL=https://nguontin.com
CORS_ALLOW_ORIGINS=https://nguontin.com,http://127.0.0.1:3007,http://127.0.0.1:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.nguontin.com/auth/sso/google/callback
